class Solution
{
public:
    int peakIndexInMountainArray(vector<int> &arr)
    {

        int n = arr.size();
        int start = 0, end = n - 1, mid;

        while (start <= end)
        {
            mid =end  + (start - end) / 2;
            // Peak Element
            if (arr[mid] > arr[mid - 1] && arr[mid] > arr[mid + 1])
            {
                return mid;
            }
            // Right Side
            else if (arr[mid] < arr[mid + 1])
            {
                start = mid + 1;
            }
            // Left Side
            else
                end = mid - 1;
        }
        return -1;
    }
};
