class Solution {
public:
    int longestPalindrome(string s) {
        vector<int> lower(26, 0);
        vector<int> upper(26, 0);

       
        for (int i = 0; i < s.size(); i++) {
            if (s[i] >= 'a' && s[i] <= 'z') {
                lower[s[i] - 'a']++;
            } else if (s[i] >= 'A' && s[i] <= 'Z') {
                upper[s[i] - 'A']++;
            }
        }

        int count = 0;
        bool odd = false;

        // lowercase
        for (int i = 0; i < 26; i++) {
            count += (lower[i] / 2) * 2;
            if (lower[i] % 2 == 1) odd = true;
        }

        //  uppercase
        for (int i = 0; i < 26; i++) {
            count += (upper[i] / 2) * 2;
            if (upper[i] % 2 == 1) odd = true;
        }

  
        if (odd) count += 1;

        return count;
    }
};

