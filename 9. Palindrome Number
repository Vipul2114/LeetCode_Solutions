class Solution
{
public:
    bool isPalindrome(int x)
    {
        if (x < 0)
            return false;

        int num = x;
        long long ans = 0;
        while (x)
        {
            int rem = x % 10;
            x = x / 10;
            ans = ans * 10 + rem;
        }
        return ans == num;
    }
};
